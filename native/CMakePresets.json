{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 27,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "BUILD_TESTS": "ON",
                "FETCHCONTENT_BASE_DIR": "${sourceDir}/build/_deps"
            }
        },
        {
            "name": "desktop-debug",
            "displayName": "Desktop Debug (auto-detect toolchain)",
            "description": "Development build — debug symbols, ASan on supported platforms, tests enabled",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "ENABLE_ASAN": "ON"
            }
        },
        {
            "name": "windows-release",
            "displayName": "Windows Release (MSVC)",
            "description": "Optimised Windows build — MSVC, Vulkan GPU backend",
            "inherits": "base",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "ENABLE_ASAN": "OFF"
            },
            "generator": "Visual Studio 17 2022",
            "architecture": "x64"
        },
        {
            "name": "macos-release",
            "displayName": "macOS Release (Clang)",
            "description": "Optimised macOS build — Clang, Metal GPU backend",
            "inherits": "base",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "ENABLE_ASAN": "OFF"
            }
        },
        {
            "name": "linux-release",
            "displayName": "Linux Release (GCC/Clang)",
            "description": "Optimised Linux build — Vulkan GPU backend",
            "inherits": "base",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            },
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "ENABLE_ASAN": "OFF"
            }
        },
        {
            "name": "ios-release",
            "displayName": "iOS Release (Xcode)",
            "description": "iOS release — Metal GPU backend, no tests (cross-compiled)",
            "inherits": "base",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            },
            "generator": "Xcode",
            "cacheVariables": {
                "CMAKE_SYSTEM_NAME": "iOS",
                "CMAKE_OSX_DEPLOYMENT_TARGET": "15.0",
                "CMAKE_OSX_ARCHITECTURES": "arm64",
                "CMAKE_BUILD_TYPE": "Release",
                "BUILD_TESTS": "OFF",
                "ENABLE_ASAN": "OFF"
            }
        },
        {
            "name": "android-release",
            "displayName": "Android Release (NDK)",
            "description": "Android release — Vulkan GPU backend, requires ANDROID_NDK_HOME",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_SYSTEM_NAME": "Android",
                "CMAKE_ANDROID_NDK": "$env{ANDROID_NDK_HOME}",
                "CMAKE_ANDROID_API": "26",
                "CMAKE_ANDROID_ARCH_ABI": "arm64-v8a",
                "CMAKE_ANDROID_STL_TYPE": "c++_shared",
                "CMAKE_BUILD_TYPE": "Release",
                "BUILD_TESTS": "OFF",
                "ENABLE_ASAN": "OFF"
            }
        },
        {
            "name": "wasm-release",
            "displayName": "WebAssembly Release (Emscripten)",
            "description": "WASM release — WebGL GPU backend, requires emsdk",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "$env{EMSDK}/upstream/emscripten/cmake/Modules/Platform/Emscripten.cmake",
                "CMAKE_BUILD_TYPE": "Release",
                "BUILD_TESTS": "OFF",
                "ENABLE_ASAN": "OFF"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "desktop-debug",
            "configurePreset": "desktop-debug"
        },
        {
            "name": "windows-release",
            "configurePreset": "windows-release",
            "configuration": "Release"
        },
        {
            "name": "macos-release",
            "configurePreset": "macos-release"
        },
        {
            "name": "linux-release",
            "configurePreset": "linux-release"
        },
        {
            "name": "ios-release",
            "configurePreset": "ios-release",
            "configuration": "Release"
        },
        {
            "name": "android-release",
            "configurePreset": "android-release"
        },
        {
            "name": "wasm-release",
            "configurePreset": "wasm-release"
        }
    ],
    "testPresets": [
        {
            "name": "desktop-debug",
            "configurePreset": "desktop-debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "windows-release",
            "configurePreset": "windows-release",
            "configuration": "Release",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "macos-release",
            "configurePreset": "macos-release",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "linux-release",
            "configurePreset": "linux-release",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}
